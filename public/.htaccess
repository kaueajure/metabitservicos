<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteRule ^database(/.*)?$ - [F,L]
  RewriteRule ^api(/.*)?$ api/index.php [QSA,L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . index.html [L]
</IfModule>

<FilesMatch "^\.env">
  Require all denied
</FilesMatch>
